# Frontend (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional backend API (set only if running Node API server)
# Example: http://localhost:3001/api
VITE_API_URL=

# Server-side (required only for `npm run dev:server` or `npm run dev:all`)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Fallback if service role key is not used
SUPABASE_ANON_KEY=

# Optional
FRONTEND_URL=http://localhost:5173
PORT=3001
